{
  "name": "search_github",
  "description": "Search issues in a GitHub repository.",
  "input_schema": {
    "type": "object",
    "properties": {
      "repo": {
        "type": "string"
      },
      "query": {
        "type": "string"
      },
      "limit": {
        "type": "integer",
        "default": 10
      }
    },
    "additionalProperties": false,
    "required": [
      "repo",
      "query"
    ]
  }
}
