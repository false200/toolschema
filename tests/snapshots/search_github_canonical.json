{
  "name": "search_github",
  "description": "Search issues in a GitHub repository.",
  "parameters": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "repo": {
        "type": "string"
      },
      "query": {
        "type": "string"
      },
      "limit": {
        "type": "integer",
        "default": 10
      }
    },
    "additionalProperties": false,
    "required": [
      "repo",
      "query"
    ]
  },
  "output": {
    "type": "array",
    "items": {
      "type": "object"
    }
  }
}
